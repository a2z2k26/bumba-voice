# PTT (Push-to-Talk) Configuration
# This file is automatically loaded by voice_mode
BUMBA_PTT_ENABLED=true
BUMBA_PTT_MODE=hold
BUMBA_PTT_KEY_COMBO=option_r
BUMBA_PTT_CANCEL_KEY=escape
BUMBA_PTT_TIMEOUT=120

# Visual Feedback
BUMBA_PTT_VISUAL_FEEDBACK=true
BUMBA_PTT_VISUAL_STYLE=compact
BUMBA_PTT_SHOW_DURATION=true

# Audio Feedback
BUMBA_PTT_AUDIO_FEEDBACK=true

# Statistics
BUMBA_PTT_STATISTICS=true

# ============================================================================
# Latency Optimization Settings (LOW_RISK_LATENCY_IMPROVEMENTS.md)
# ============================================================================

# Optimization #1: Streaming Configuration
# Reduces buffering latency for faster audio start
# Default values: CHUNK_SIZE=4096, BUFFER_MS=150, MAX_BUFFER=2.0
BUMBA_STREAM_CHUNK_SIZE=2048
BUMBA_STREAM_BUFFER_MS=100
BUMBA_STREAM_MAX_BUFFER=1.0

# Optimization #2: PCM Format for Lowest Latency
# Uses uncompressed PCM format to eliminate decoding overhead (100-300ms improvement)
# Trade-off: Higher bandwidth (~192 KB/s vs ~24 KB/s for Opus)
BUMBA_TTS_AUDIO_FORMAT=pcm

# Optimization #3: Connection Pre-warming
# Pre-establish HTTP connections to TTS/STT providers during startup
# Eliminates 80-350ms cold-start latency on first request
BUMBA_WARMUP_PROVIDERS=true
