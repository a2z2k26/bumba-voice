# PTT (Push-to-Talk) Configuration
# This file is automatically loaded by voice_mode
BUMBA_PTT_ENABLED=true
BUMBA_PTT_MODE=hold
BUMBA_PTT_KEY_COMBO=option_r
BUMBA_PTT_CANCEL_KEY=escape
BUMBA_PTT_TIMEOUT=120

# Visual Feedback
BUMBA_PTT_VISUAL_FEEDBACK=true
BUMBA_PTT_VISUAL_STYLE=compact
BUMBA_PTT_SHOW_DURATION=true

# Audio Feedback
BUMBA_PTT_AUDIO_FEEDBACK=true

# Statistics
BUMBA_PTT_STATISTICS=true
